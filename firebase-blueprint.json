{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "clerk"] },
        "branch": { "type": "string" }
      },
      "required": ["uid", "email", "role"]
    },
    "InventoryItem": {
      "title": "Inventory Item",
      "description": "A mobile device or accessory in stock",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "imei": { "type": "string" },
        "valuation": { "type": "number" },
        "status": { "type": "string", "enum": ["IN_STOCK", "LENT", "SOLD"] },
        "category": { "type": "string", "enum": ["PHONES", "TABLETS", "ACCESSORIES"] },
        "lastUpdated": { "type": "string", "format": "date-time" },
        "lentTo": { "type": "string" },
        "expectedReturnDate": { "type": "string", "format": "date" }
      },
      "required": ["id", "name", "imei", "valuation", "status", "category"]
    },
    "Transaction": {
      "title": "Transaction",
      "description": "A ledger entry for sales, purchases, or transfers",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "type": { "type": "string", "enum": ["SALE", "PURCHASE", "LENT", "BORROWED", "EXPENSE", "VOID", "RETURNED", "TRANSFER"] },
        "item": { "type": "string" },
        "amount": { "type": "number" },
        "timestamp": { "type": "string", "format": "date-time" },
        "clerk": { "type": "string" },
        "clerkId": { "type": "string" },
        "status": { "type": "string", "enum": ["SETTLED", "PENDING", "VOIDED", "COMPLETED", "IN_TRANSIT", "APPROVED"] },
        "imei": { "type": "string" },
        "location": { "type": "string" },
        "source": { "type": "string" },
        "direction": { "type": "string", "enum": ["SEND", "RECEIVE"] },
        "transferType": { "type": "string", "enum": ["ASSET", "CASH"] }
      },
      "required": ["id", "type", "item", "amount", "timestamp", "clerk", "status"]
    },
    "Notification": {
      "title": "Notification",
      "description": "System notifications for events",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "msg": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "type": { "type": "string", "enum": ["info", "warning", "success", "error"] }
      },
      "required": ["title", "msg", "timestamp", "type"]
    },
    "Branch": {
      "title": "Branch",
      "description": "A store branch or network node",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name"]
    },
    "Invite": {
      "title": "Invite",
      "description": "An invitation for a clerk to join a store",
      "type": "object",
      "properties": {
        "email": { "type": "string", "format": "email" },
        "invitedBy": { "type": "string" },
        "invitedByEmail": { "type": "string" },
        "status": { "type": "string", "enum": ["PENDING", "ACCEPTED", "DECLINED"] },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["email", "invitedBy", "status"]
    },
    "Reconciliation": {
      "title": "Reconciliation",
      "description": "End-of-day reconciliation report submitted by a clerk",
      "type": "object",
      "properties": {
        "timestamp": { "type": "string", "format": "date-time" },
        "clerkId": { "type": "string" },
        "clerkName": { "type": "string" },
        "branch": { "type": "string" },
        "physicalCash": { "type": "number" },
        "physicalInventory": { "type": "number" },
        "summary": { "type": "object" },
        "soldItems": { "type": "array" }
      },
      "required": ["timestamp", "clerkId", "clerkName", "branch", "physicalCash", "physicalInventory"]
    },
    "BankAccount": {
      "title": "Bank Account",
      "description": "A company bank account",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "bankName": { "type": "string" },
        "accountNumber": { "type": "string" },
        "balance": { "type": "number" },
        "currency": { "type": "string" },
        "color": { "type": "string" }
      },
      "required": ["bankName", "accountNumber", "balance"]
    },
    "BankTransaction": {
      "title": "Bank Transaction",
      "description": "A transaction associated with a bank account",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "bankAccountId": { "type": "string" },
        "type": { "type": "string", "enum": ["DEPOSIT", "WITHDRAWAL", "TRANSFER"] },
        "amount": { "type": "number" },
        "activity": { "type": "string" },
        "project": { "type": "string" },
        "to": { "type": "string" },
        "date": { "type": "string", "format": "date-time" }
      },
      "required": ["bankAccountId", "type", "amount", "date"]
    },
    "Warehouse": {
      "title": "Warehouse",
      "description": "A distribution center or storage node",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "location": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "location"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/inventory/{itemId}": {
      "schema": "InventoryItem",
      "description": "Inventory items"
    },
    "/transactions/{transactionId}": {
      "schema": "Transaction",
      "description": "Transaction ledger"
    },
    "/notifications/{notificationId}": {
      "schema": "Notification",
      "description": "System notifications"
    },
    "/branches/{branchId}": {
      "schema": "Branch",
      "description": "Store branches"
    },
    "/invites/{inviteId}": {
      "schema": "Invite",
      "description": "Clerk invitations"
    },
    "/reconciliations/{reconciliationId}": {
      "schema": "Reconciliation",
      "description": "EOD reconciliation reports"
    },
    "/bankAccounts/{accountId}": {
      "schema": "BankAccount",
      "description": "Company bank accounts"
    },
    "/bankTransactions/{transactionId}": {
      "schema": "BankTransaction",
      "description": "Bank account transaction history"
    },
    "/warehouses/{warehouseId}": {
      "schema": "Warehouse",
      "description": "Asset storage warehouses"
    }
  }
}
